<!-- 个人设置页 -->
<view class="container">
  <view class="header">
    <text class="title">个人设置</text>
  </view>
  
  <!-- 用户信息区域 -->
  <view class="user-section">
    <!-- 已登录状态 -->
    <view class="user-info" wx:if="{{userInfo.nickName}}">
      <!-- 显示微信头像（圆形） -->
      <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
      <!-- 显示微信昵称 -->
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>
    
    <!-- 未登录状态 -->
    <view class="login-section" wx:else>
      <!-- 微信授权登录按钮 -->
      <button class="wechat-login-btn" bindtap="goToIndexLogin">去首页登录</button>
      <text class="login-hint">登录后可查看个人信息和打卡记录</text>
    </view>
  </view>
  
  <!-- 设置项 -->
  <view class="setting-list">
    <!-- 修改打卡范围（仅管理员可见） -->
    <view class="setting-item" wx:if="{{isAdmin}}" bindtap="modifyCheckInRange">
      <text class="setting-label">修改打卡范围</text>
      <text class="setting-arrow">→</text>
    </view>
    
    <!-- 清除本地缓存 -->
    <view class="setting-item bordered" bindtap="clearCache">
      <text class="setting-label">清除本地缓存</text>
      <text class="setting-arrow">→</text>
    </view>
    
    <!-- 关于 -->
    <view class="setting-item bordered" bindtap="showAbout">
      <text class="setting-label">关于</text>
      <text class="setting-arrow">→</text>
    </view>
  </view>
</view>