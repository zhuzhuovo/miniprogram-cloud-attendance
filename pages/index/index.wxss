/** 打卡首页样式 **/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 头部信息 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.login-btn {
  width: 180rpx;
  height: 60rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.login-hint {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

/* 登录弹窗：头像昵称填写 */
.login-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.login-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 101;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.login-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
}

.login-modal-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 36rpx;
}

.login-form-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: block;
}

.avatar-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.login-form-nickname {
  margin-bottom: 36rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.nickname-placeholder {
  color: #bbb;
}

.login-form-btns {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.login-modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.login-modal-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.login-modal-btn.confirm {
  background: #4CAF50;
  color: #fff;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.current-time {
  font-size: 24rpx;
  color: #666;
}

/* 打卡状态 */
.status-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx; /* 布局优化：增加底部间距 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.status-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.status-content {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 地图组件 */
.map-section {
  /* 解决地图尺寸：确保宽度100%，高度450rpx */
  width: 100%;
  height: 450rpx;
  margin: 30rpx 0; /* 解决地图尺寸：调整上下间距 */
  /* 解决地图尺寸：添加1px灰色边框+轻微阴影 */
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  background-color: #f5f5f5;
}

.map {
  /* 解决地图尺寸：宽度100%，高度100% */
  width: 100%;
  height: 100%;
}

/* 位置信息 */
.location-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx; /* 布局优化：增加底部间距 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.location-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.location-content {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.location-hint {
  font-size: 22rpx;
  color: #FF5722;
}

/* 打卡按钮 */
.checkin-section {
  display: flex;
  flex-direction: column;
  align-items: center; /* 布局优化：按钮居中显示 */
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.checkin-btn {
  /* 布局优化：按钮宽度80%左右，样式更醒目 */
  width: 80%;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  background-color: #4CAF50;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 视觉优化：添加阴影，增强视觉效果 */
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.checkin-btn.off {
  background-color: #2196F3;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.3);
}

.checkin-btn.disabled {
  background-color: #e0e0e0;
  color: #9e9e9e;
  box-shadow: none;
}

/* 错误提示 */
.error-section {
  background-color: #FFF3E0;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.error-msg {
  font-size: 24rpx;
  color: #FF5722;
}
